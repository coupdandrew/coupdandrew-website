---
import astroLogo from "../assets/astro.svg";
---

<div id="container">
  <main>
    <section id="hero">
      <h1>
        Hey, I'm <pre>Andrew</pre>. 😃
      </h1>
      <h2>This space is under construction.</h2>
      <p>I hope to have this place in better shape soon. See you then!</p>
    </section>
  </main>
</div>

<style>
  #container {
    font-family:
      Inter, Roboto, "Helvetica Neue", "Arial Nova", "Nimbus Sans", Arial,
      sans-serif;
    height: 100%;
    background-image: url(assets/background.svg);
    background-size: cover;
  }

  main {
    display: flex;
    justify-content: center;
  }

  #hero {
    margin-block-start: 30vh;
    display: flex;
    align-items: start;
    flex-direction: column;
    justify-content: center;
    padding: 16px;
    background: rgb(255, 255, 255);
  }

  h1 {
    font-size: 48px;
    margin-top: 0.25em;
  }

  h2 {
    font-size: 22px;
    margin-top: 0.25em;
  }

  pre {
    display: inline;
    font-weight: bolder;
    background: linear-gradient(
      14deg,
      rgb(216, 26, 27),
      rgb(252, 135, 9),
      rgb(255, 202, 0),
      rgb(178, 198, 13),
      rgb(27, 91, 181),
      rgb(159, 95, 176),
      rgb(255, 44, 113)
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  @media screen and (max-width: 768px) {
    #container {
      display: flex;
      flex-direction: column;
    }

    #hero {
      display: block;
      padding-top: 10%;
    }

    h1 {
      line-height: 1.5;
    }
  }
</style>
